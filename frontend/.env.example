VITE_APP_NAME=Link2Pay
VITE_API_URL=http://localhost:3001

# Network is fixed per deployment — there is no in-app switcher.
#   • Leave the three vars below UNSET on the production domain → defaults to Mainnet.
#   • A `testnet.*` hostname auto-resolves to Testnet with no env needed.
#   • Set them explicitly to force a network (e.g. for local testnet dev, below).
# Resolution order: VITE_STELLAR_NETWORK env → `testnet.` hostname → mainnet.
VITE_STELLAR_NETWORK=testnet
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Privy social login (Google / email → Stellar embedded wallet).
# Get your app ID from https://dashboard.privy.io
# When set, replaces the Freighter connect button with a "Sign in" button.
# VITE_PRIVY_APP_ID=clxxxxxxxxxxxxxxxxxxxxxxxxx
